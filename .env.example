# ========================================
# KLASS JEWELRY - Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to GitHub

# --- Supabase ---
# Get from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Stripe ---
# Get from: dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# --- Stripe Webhook ---
# Get from: dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# --- App URL ---
# Local development
NEXT_PUBLIC_URL=http://localhost:3000
# Production (change after deploying to Vercel)
# NEXT_PUBLIC_URL=https://klass-jewelry.vercel.app
